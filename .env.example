# ---------------------------------------------------------
# Bosch Azure OpenAI API Configuration
# ---------------------------------------------------------

# Your Bosch LLM API key
BOSCH_LLM_API_KEY=your-api-key-here

# Base URL
BOSCH_LLM_BASE_URL=https://aoai-farm.bosch-temp.com/api

# API version
BOSCH_LLM_API_VERSION=2025-04-01-preview

# Deployment name — check the Bosch LLM Farm Model Catalog
# Confirmed working:
#   askbosch-prod-farm-openai-gpt-4o-mini-2024-07-18
# To use Claude, find the exact name in the Model Catalog
BOSCH_LLM_DEPLOYMENT=askbosch-prod-farm-openai-gpt-4o-mini-2024-07-18
